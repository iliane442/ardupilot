def move_on_landing_strip(master):

    set_mode(master, 'FBWA')
    master.mav.command_long_send( master.target_system, master.target_component,
    mavutil.mavlink.MAV_CMD_GET_HOME_POSITION,
    0, 0,0,0,0,0,0,0)
    
    msg = master.recv_match(type='HOME_POSITION', blocking=True, timeout=5)
    initial_altitude = msg.altitude / 1000              ## pour passer des mm au mètres
    airspeed = 0 
    minimal_takeoff_speed = 10                          ## m/sec 

  # throttle_chan = 3   par défaut, à modifier si jamais ce n'est pas ca sur l'avion réel
  # rudder_chan = 4     par défaut, à modifier si jamais ce n'est pas ca sur l'avion réel
  
    throttle_min = 1200  # début de l'accélération, correspond à un PMW 
    throttle_max = 1700  # moteur presque à fond
    rudder_neutral = 1500  # maintenir la direction droite

    t = throttle_min
    # Boucle progressive jusqu'à atteindre la vitesse de décollage
    while airspeed < minimal_takeoff_speed:
        if t>= throttle_max: 
            t= throttle_max

        master.mav.rc_channels_override_send(
            master.target_system,
            master.target_component,
            0,              # CH1 = aileron
            0,              # CH2 = elevator
            t,              # CH3 = throttle
            rudder_neutral, # CH4 = rudder
            0, 0, 0, 0      # CH5-CH8 non utilisés
        )
        print(f"Throttle PWM = {t}")

        # Lecture de la vitesse
        hud_msg = master.recv_match(type='VFR_HUD', blocking=True, timeout=2)
        if hud_msg: 
            airspeed = hud_msg.airspeed
            groundspeed = hud_msg.groundspeed
            print(f"Airspeed = {airspeed:.1f} m/s, Groundspeed = {groundspeed:.1f} m/s")
        else:
            print('incapable de lire la valeur de la vitesse')
            return 
        t += 50
        time.sleep(0.5)  ## laisse le temps à l'avion d'accélérer

    print("Vitesse minimale atteinte, prêt pour décollage !")
    set_mode(master, 'AUTO')
    return 

